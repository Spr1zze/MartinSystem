{
  "name": "martin-inventory",
  "description": "System tailored to Martin",
  "author": "Joachim Siedler",
  "version": "1.0.0",
  "main": "public/main.js",
  "homepage": "./",
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "concurrently": "^8.2.0",
    "electron-is-dev": "^2.0.0"
  },
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"cd frontend && npm run dev\" \"electron .\"",
    "dev-browser": "concurrently \"cd backend && dotnet run\" \"cd frontend && npm run dev\"",
    "build-backend": "cd backend && dotnet publish -c Release",
    "build-frontend": "cd frontend && npm run build",
    "build": "npm run build-backend && npm run build-frontend",
    "electron-build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.martinInventory",
    "files": [
      "public/main.js",
      "frontend/dist/**/*",
      "backend/bin/Release/net8.0/**/*"
    ],
    "win": {
      "target": ["nsis"]
    }
  }
}